datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Settings {
  id                        String   @id @default("settings")
  siteName                  String   @db.Text
  siteSubtitle              String   @db.Text
  primaryColor              String
  themeMode                 String
  contactFacebook           String   @db.Text
  contactDiscord            String   @db.Text
  contactLine               String   @db.Text
  truewalletPhone           String
  bankAccountNumber         String?
  bankAccountName           String?
  bankName                  String?
  qrSlipToken               String   @db.Text
  botCfTurnstileKey         String   @db.Text
  discordClientId           String   @db.Text
  discordClientSecret       String   @db.Text
  banners                   Json
  allowAngpao               Boolean
  allowQr                   Boolean
  siteLogoUrl               String?  @db.Text
  siteBackgroundUrl         String?  @db.Text
  announcementActive        Boolean?
  announcementTitle         String?  @db.Text
  announcementBody          String?  @db.Text
  announcementImageUrl      String?  @db.Text
  announcementBarActive      Boolean?
  announcementBarText       String?  @db.Text
  announcementBarBgColor    String?
  announcementBarTextColor  String?
  announcementBarSpeed      Float?
  announcementBarStyle      String?
  announcementBarPrefix     String?
  announcementFloatActive   Boolean?
  announcementFloatText     String?  @db.Text
  announcementFloatStyle    String?
  announcementFloatIcon     String?
  announcementFloatPosition String?
  maintenanceActive         Boolean?
  maintenanceTitle          String?  @db.Text
  maintenanceMessage        String?  @db.Text
  maintenanceEstimatedTime  String?
  maintenanceAutoOpenTime   String?
  aboutUsTitle              String?  @db.Text
  aboutUsBody               String?  @db.Text
  aboutUsImageUrl           String?  @db.Text
  portfolios                Json?
  artisans                  Json?
  landmarks                 Json?
  recommendActive           Boolean?
  recommendTitle            String?  @db.Text
  recommendSubtitle         String?  @db.Text
  recommendProductIds       Json?
  seasonalEffect            String?
  recentOrdersActive        Boolean?
  recentOrdersStyle         String?
  recentOrdersSpeed         String?
}

model Category {
  id          String @id
  name        String
  description String @db.Text
  icon        String
  imageUrl    String @db.Text
}

model Product {
  id          String  @id
  categoryId  String
  name        String  @db.Text
  price       Float
  description String  @db.Text
  imageUrl    String  @db.Text
  stock       Json
  timesSold   Int     @default(0)
  details     String  @db.Text
  type        String  // 'normal' | 'box'
  videoUrl    String? @db.Text
  boxItems    Json?
  sellerId    String?
  sellerName  String?
  sellerType  String?
}

model User {
  id                  String  @id
  username            String  @unique
  email               String  @unique
  balance             Float   @default(0)
  role                String  // 'user' | 'admin' | 'seller_internal' | 'seller_external'
  discordId           String?
  avatarUrl           String? @db.Text
  password            String? @db.Text
  pendingBalance      Float?  @default(0)
  withdrawableBalance Float?  @default(0)
}

model Coupon {
  code            String @id
  discountPercent Float  @default(0)
  discountBaht    Float  @default(0)
  usesLeft        Int    @default(0)
}

model Transaction {
  id              String  @id
  userId          String
  username        String
  type            String
  amount          Float
  details         String  @db.Text
  status          String
  date            String
  shippingDetails Json?
  orderStatus     String?
  trackingNumber  String?
  trackingCarrier String?
  statusUpdates   Json?
}

model Review {
  id          String @id
  userId      String
  username    String
  rating      Int
  productId   String
  productName String @db.Text
  comment     String @db.Text
  date        String
}

model Conversation {
  id                String   @id
  customerId        String
  sellerId          String
  shopId            String
  lastMessage       String   @db.Text
  lastMessageAt     String
  status            String
  createdAt         String
  isTypingSeller    Boolean?
  isTypingCustomer  Boolean?
}

model Message {
  id             String  @id
  conversationId String
  senderId       String
  message        String  @db.Text
  messageType    String
  image          String? @db.Text
  isRead         Boolean @default(false)
  createdAt      String
  replyToId      String?
  replyToMessage String? @db.Text
  productInfo    Json?
  orderInfo      Json?
  locationInfo   Json?
}

model Notification {
  id        String  @id
  userId    String
  title     String  @db.Text
  body      String  @db.Text
  isRead    Boolean @default(false)
  createdAt String
}

model SellerVerification {
  id                String   @id
  userId            String
  username          String
  email             String
  shopName          String
  shopDescription   String   @db.Text
  idCardPhotoUrl    String   @db.Text
  status            String
  submittedAt       String
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  adminNotes        String?  @db.Text
  reviewedAt        String?
}

model Withdrawal {
  id                String   @id
  userId            String
  username          String
  amount            Float
  bankName          String
  bankAccountNumber String
  bankAccountName   String
  status            String
  submittedAt       String
  adminNotes        String?  @db.Text
  slipUrl           String?  @db.Text
  reviewedAt        String?
}
